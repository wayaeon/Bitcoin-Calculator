{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Realtime BTC Updater",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/start-realtime-updater.js"],
      "autoPort": true
    },
    {
      "name": "Update Currency Rates",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "scripts/update-currency-rates.mjs"],
      "autoPort": true
    }
  ]
}
